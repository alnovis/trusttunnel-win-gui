// Resource script compiled by embed-resource (see build.rs): the manifest,
// the app/tray icon, and the settings dialogs.

#include <windows.h>
#include "resource.h"

// RT_MANIFEST (24) with id 1 attaches the manifest to the EXE.
1 24 "app.manifest"

// Default application + tray icon (resource id 1).
1 ICON "../assets/app.ico"

//////////////////////////////////////////////////////////////////////////////
// Settings dialog (MVP)
//////////////////////////////////////////////////////////////////////////////
IDD_SETTINGS DIALOGEX 0, 0, 252, 356
STYLE DS_MODALFRAME | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "TrustTunnel - Settings"
FONT 8, "MS Shell Dlg"
BEGIN
    PUSHBUTTON      "Import from .toml...", IDC_IMPORT,   7,   7, 100, 14
    PUSHBUTTON      "Advanced...",          IDC_ADVANCED, 175, 7,  70, 14

    LTEXT           "Name:",        -1,          7,  27, 60, 10
    EDITTEXT                        IDE_NAME,    74,  25, 170,12, ES_AUTOHSCROLL
    LTEXT           "Hostname:",    -1,          7,  43, 60, 10
    EDITTEXT                        IDE_HOSTNAME,74,  41, 170,12, ES_AUTOHSCROLL
    LTEXT           "Username:",    -1,          7,  59, 60, 10
    EDITTEXT                        IDE_USERNAME,74,  57, 170,12, ES_AUTOHSCROLL
    LTEXT           "Password:",    -1,          7,  75, 60, 10
    EDITTEXT                        IDE_PASSWORD,74,  73, 170,12, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT           "Protocol:",    -1,          7,  91, 60, 10
    COMBOBOX                        IDC_PROTOCOL,74,  89, 80, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Fallback:",    -1,          7, 107, 60, 10
    COMBOBOX                        IDC_FALLBACK,74, 105, 80, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Addresses (one ip:port per line):", -1, 7, 123, 237, 10
    EDITTEXT                        IDE_ADDRESSES, 7, 135, 237, 26, ES_MULTILINE | ES_WANTRETURN | WS_VSCROLL | ES_AUTOVSCROLL

    LTEXT           "Certificate (PEM, empty = system store):", -1, 7, 165, 237, 10
    EDITTEXT                        IDE_CERT,     7, 177, 237, 32, ES_MULTILINE | ES_WANTRETURN | WS_VSCROLL | ES_AUTOVSCROLL

    AUTOCHECKBOX    "Skip certificate verification", IDC_SKIPVERIFY, 7, 213, 237, 10

    AUTOCHECKBOX    "Enable split tunneling (geoip)", IDC_SPLIT, 7, 227, 237, 10
    LTEXT           "RIR:",         -1,          7, 241, 60, 10
    COMBOBOX                        IDC_RIR,     74, 239, 90, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Country (ISO):",-1,         7, 257, 60, 10
    EDITTEXT                        IDE_COUNTRY, 74, 255, 40, 12, ES_AUTOHSCROLL | ES_UPPERCASE
    LTEXT           "Refresh (hours):",-1,       7, 273, 60, 10
    EDITTEXT                        IDE_REFRESH, 74, 271, 40, 12, ES_AUTOHSCROLL | ES_NUMBER

    AUTOCHECKBOX    "Kill switch",  IDC_KILLSWITCH, 7, 287, 237, 10
    LTEXT           "Log level:",   -1,          7, 303, 60, 10
    COMBOBOX                        IDC_LOGLEVEL,74, 301, 80, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Engine exe:",  -1,          7, 321, 60, 10
    EDITTEXT                        IDE_ENGINE,  74, 319, 130,12, ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...",    IDC_BROWSE, 208, 319, 36, 12

    PUSHBUTTON      "Change password...", IDC_CHANGEPW, 7, 339, 100, 14
    DEFPUSHBUTTON   "OK",           IDOK,       138, 339, 50, 14
    PUSHBUTTON      "Cancel",       IDCANCEL,   194, 339, 50, 14
END

//////////////////////////////////////////////////////////////////////////////
// Advanced dialog
//////////////////////////////////////////////////////////////////////////////
IDD_ADVANCED DIALOGEX 0, 0, 252, 200
STYLE DS_MODALFRAME | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "TrustTunnel - Advanced"
FONT 8, "MS Shell Dlg"
BEGIN
    AUTOCHECKBOX    "Route IPv6 through VPN",    IDC_IPV6,      7,   7, 237, 10
    AUTOCHECKBOX    "Anti-DPI",                  IDC_ANTIDPI,   7,  21, 237, 10
    AUTOCHECKBOX    "Post-quantum crypto",       IDC_PQ,        7,  35, 237, 10
    AUTOCHECKBOX    "Let engine change system DNS", IDC_CHANGEDNS, 7, 49, 237, 10

    LTEXT           "client_random (prefix[/mask]):", -1, 7, 65, 110, 10
    EDITTEXT                        IDE_CLIENTRANDOM, 120, 63, 124, 12, ES_AUTOHSCROLL
    LTEXT           "custom_sni:",  -1,          7,  81, 110, 10
    EDITTEXT                        IDE_CUSTOMSNI,120, 79, 124, 12, ES_AUTOHSCROLL
    LTEXT           "MTU size:",    -1,          7,  97, 110, 10
    EDITTEXT                        IDE_MTU,     120, 95,  40, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "DNS upstreams (one per line):", -1, 7, 113, 237, 10
    EDITTEXT                        IDE_DNS,      7, 125, 237, 26, ES_MULTILINE | ES_WANTRETURN | WS_VSCROLL | ES_AUTOVSCROLL

    LTEXT           "Kill switch allow ports (comma):", -1, 7, 157, 130, 10
    EDITTEXT                        IDE_KSPORTS, 140, 155, 104, 12, ES_AUTOHSCROLL

    DEFPUSHBUTTON   "OK",           IDOK,       138, 179, 50, 14
    PUSHBUTTON      "Cancel",       IDCANCEL,   194, 179, 50, 14
END

//////////////////////////////////////////////////////////////////////////////
// Password dialog (unlock / first-run create)
//////////////////////////////////////////////////////////////////////////////
IDD_PASSWORD DIALOGEX 0, 0, 200, 104
STYLE DS_MODALFRAME | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "TrustTunnel"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Enter password:", IDC_PWINFO, 7,  7, 186, 10
    LTEXT           "Password:",       -1,         7, 25,  50, 10
    EDITTEXT                           IDE_PW1,    60, 23, 133, 12, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT           "Confirm:",        IDL_PW2,    7, 43,  50, 10
    EDITTEXT                           IDE_PW2,    60, 41, 133, 12, ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",              IDOK,       86, 83,  50, 14
    PUSHBUTTON      "Cancel",          IDCANCEL,   143, 83, 50, 14
END
